# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Braintrust Observability ---
# Optional: enables tracing for Gemini and Mistral API calls.
# Get key from https://www.braintrust.dev/
BRAINTRUST_API_KEY=""
# Optional project override (defaults to "nguyen-trai-portfolio")
BRAINTRUST_PROJECT_NAME=""

# --- OpenTelemetry ---
# Optional: comma-separated URL prefixes/regex-like strings where fetch should
# propagate trace headers for outgoing requests.
# Defaults include localhost, Mistral, and Gemini endpoints.
OTEL_PROPAGATE_CONTEXT_URLS=""

# --- AI Integration (Mistral) ---
# Set MISTRAL_API_KEY to point to Mistral AI.
MISTRAL_API_KEY="your_api_key_here"
AI_MODEL="mistral-small-latest" # Change to "mistral-large-latest" if needed

# --- Mux (Video Hosting) ---
# Get these from https://dashboard.mux.com → Settings → Access Tokens
MUX_TOKEN_ID="your_mux_token_id_here"
MUX_TOKEN_SECRET="your_mux_token_secret_here"
# Get from dashboard.mux.com → Environments → your env → Data env key (safe to expose publicly)
NEXT_PUBLIC_MUX_DATA_ENV_KEY="your_mux_data_env_key_here"

# --- Database (Upstash Redis) ---
UPSTASH_REDIS_REST_URL="your_upstash_redis_url_here"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token_here"
# Optional: comma-separated preview URL allowlist for /api/preview.
# Only these domains (and their subdomains) are allowed for external metadata fetch.
# Example: youtube.com,youtu.be,vimeo.com,wikipedia.org
PREVIEW_ALLOWED_DOMAINS=""
# Optional but recommended: extra secret used to HMAC admin IP/session data and fallback sensitive hashing.
ADMIN_AUTH_PEPPER=""
# Optional but recommended: dedicated secret for feedback identity hashing.
FEEDBACK_HASH_PEPPER=""

# --- Cloudinary (Image/Video Uploads) ---
# Format: cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>
CLOUDINARY_URL="cloudinary://<your_api_key>:<your_api_secret>@ddurdk3rf"
# Required by next-cloudinary for the video player
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="ddurdk3rf"
